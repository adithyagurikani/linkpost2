# MongoDB
MONGODB_URI="mongodb+srv://user:password@cluster.mongodb.net/autopost"

# Auth
JWT_SECRET=change-me-to-a-random-64-char-hex-string
JWT_REFRESH_SECRET=change-me-to-another-random-64-char-hex-string
ALLOW_REGISTRATION=true

# LinkedIn OAuth
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret

# AI
OPENCODE_API_KEY=sk-your-opencode-api-key

# URLs
BASE_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000

# Server
PORT=3001
NODE_ENV=development
CRON_SECRET=change-me-to-a-random-64-char-hex-string
